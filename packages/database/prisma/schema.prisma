datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CLIENTE
  LOJA
  FORNECEDOR
  MOTORISTA
  ADMIN
}

enum OrderType {
  B2C
  B2B
  COLETA
}

enum OrderStatus {
  PENDENTE
  PREPARO
  EM_ROTA
  ENTREGUE
  CANCELADO
}

enum VehicleType {
  MOTO
  CAMINHAO
  CACAMBA
}

model User {
  id               String    @id @default(uuid())
  supabaseId       String    @unique
  selectedRole     UserRole  @default(CLIENTE)
  name             String    // Nome do dono da conta
  phone            String    @unique
  email            String    @unique
  pixKey           String?
  lat              Float     // Captura obrigatória com validação anti-mock
  lng              Float     // Captura obrigatória com validação anti-mock
  
  // --- CAMPOS DE PERSONALIZAÇÃO (WHITE-LABEL) ---
  brandName        String?   // Nome próprio do Estabelecimento/Batedeira
  brandColor       String?   @default("#5b21b6") // Cor em HEX para UI dinâmica
  logoUrl          String?   // Upload para Supabase Storage
  bannerUrl        String?   // Upload para Supabase Storage

  mpAccessToken    String?   // ARMAZENADO CRIPTOGRAFADO EM AES-256-GCM
  mpMerchantId     String?   // ID de vendedor Mercado Pago para split
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  
  products         Product[] // Relacionamento com o catálogo
}

model Product {
  id               String    @id @default(uuid())
  storeId          String
  store            User      @relation(fields: [storeId], references: [id])
  name             String
  description      String?
  imageUrl         String?   // Upload via Supabase Storage
  price            Decimal   @db.Decimal(10, 2)
  promoPrice       Decimal?  @db.Decimal(10, 2)
  isPromoActive    Boolean   @default(false)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
}

model Driver {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  vehicle       VehicleType
  lat           Float
  lng           Float
  isOnline      Boolean     @default(false)
}

model Order {
  id                 String       @id @default(uuid())
  type               OrderType
  status             OrderStatus  @default(PENDENTE)
  clientId           String?
  storeId            String?
  supplierId         String?
  driverId           String?
  originLat          Float
  originLng          Float
  destLat            Float
  destLng            Float
  distanceKm         Float
  baseValue          Decimal      @db.Decimal(10, 2)
  driverConfirmed    Boolean      @default(false)
  receiverConfirmed  Boolean      @default(false)
  mpPreferenceId     String?
  createdAt          DateTime     @default(now())
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2) // Congela o preço no momento da compra
}

model OrderFinance {
  orderId             String   @id
  freteTotal          Decimal  @db.Decimal(10, 2)
  freteCliente        Decimal  @db.Decimal(10, 2)
  freteLoja           Decimal  @db.Decimal(10, 2)
  plataformaVenda     Decimal  @db.Decimal(10, 2)
  plataformaFrete     Decimal  @db.Decimal(10, 2)
  plataformaTotal     Decimal  @db.Decimal(10, 2)
  repasMotorista      Decimal  @db.Decimal(10, 2)
  repasLoja           Decimal  @db.Decimal(10, 2)
  totalCobradoCliente Decimal  @db.Decimal(10, 2)
}

model SystemSettings {
  id                 Int      @id @default(1)
  b2cPlatPct         Decimal  @default(10.00) @db.Decimal(5, 2)
  b2cKmRate          Decimal  @default(2.00) @db.Decimal(5, 2)
  b2bPlatPct         Decimal  @default(10.00) @db.Decimal(5, 2)
  b2bKmRate          Decimal  @default(4.00) @db.Decimal(5, 2)
  colPlatPct         Decimal  @default(10.00) @db.Decimal(5, 2)
  colKmRate          Decimal  @default(8.00) @db.Decimal(5, 2)
  fundoRoleta        Decimal  @default(0.00) @db.Decimal(10, 2)
  precoDiaAcaíLitro  Decimal  @default(20.00) @db.Decimal(10, 2)
}
